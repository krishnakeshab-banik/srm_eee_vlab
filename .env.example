# Authentication
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-hex-32
AUTH_SECRET=replace-with-openssl-rand-hex-32
AUTH_TRUST_HOST=true

# Admin credentials
ADMIN_EMAILS=admin@srmist.edu.in
ADMIN_PASSWORD=your-secure-admin-password

# API Configuration
# Leave empty for same-origin deploy (Vercel or Render monolith).
# For split deploy: set to your Render backend URL (e.g. https://your-app.onrender.com)
NEXT_PUBLIC_API_URL=

# Frontend URL (set on Render backend when Vercel hosts the UI)
FRONTEND_URL=
NEXT_PUBLIC_FRONTEND_URL=

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/srm_vlab?retryWrites=true&w=majority

# Supabase Configuration (file uploads + admin invites)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase public keys (for client-side usage if needed)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional OAuth providers
GITHUB_ID=
GITHUB_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional AI assistant
NVIDIA_API_KEY=
